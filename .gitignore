### Generated artifacts — regenerated by :generator:generator / :ewt.api:jextract / :widgets:ffigen ###
# These monolithic files change entirely when any widget is added; committing them
# causes unavoidable merge conflicts when multiple devs add widgets in parallel.
# All devs and CI have the full toolchain, so they are always regenerated locally.
widgets/src/factories.h
widgets/src/objects.h
widgets/src/typedefs.h
widgets/lib/factories_gen.dart
widgets/lib/subwidgets.dart
generator/lib/subwidgets.dart
widgets/lib/widgets_bindings_generated.dart
ewt.api/src/main/java/dev/equo/ewt/ffm/

### Flutter ###
# Per-environment dependency redirect (e.g. CI points swtflutter at its swt-evolve clone).
# The committed pubspec.yaml keeps the local default; overrides must never be committed.
pubspec_overrides.yaml
# evolve-app is assembled with `flutter assemble` (no per-platform runner) and the native
# window is created by Evolve, so its generated platform runner scaffolding is not needed.
evolve-app/linux/
evolve-app/macos/
evolve-app/windows/